{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "LumoRPA",
  "version": "0.1.0",
  "identifier": "io.lumorpa.desktop",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "enableGTKAppId": true,
    "windows": [
      {
        "label": "main",
        "title": "LumoRPA",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "transparent": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Transparent",
        "backgroundColor": "#FFFFFF00",
        "windowEffects": {
          "effects": ["windowBackground", "micaLight", "acrylic", "blur"],
          "state": "active",
          "radius": 8,
          "color": "#FFFFFFFF"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "LumoRPA Contributors",
    "homepage": "https://lumorpa.io",
    "category": "Productivity",
    "shortDescription": "AI-native desktop RPA workbench.",
    "longDescription": "LumoRPA is a general-purpose desktop automation workbench for validating, running and inspecting LumoFlow automation workflows.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../examples": "examples",
      "../../../README.md": "README.md",
      "../../../LICENSE": "LICENSE"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "compression": "lzma"
      }
    },
    "linux": {
      "deb": {
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "release": "1"
      }
    }
  }
}
